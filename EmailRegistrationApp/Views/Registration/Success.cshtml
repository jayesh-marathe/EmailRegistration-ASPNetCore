@{
    ViewData["Title"] = "Registration Successful";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EmailRegistrationApp</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .success-checkmark {
            width: 80px;
            height: 80px;
            margin: 0 auto 2rem;
            background: rgba(16, 185, 129, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--success);
            animation: scaleIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .alert-success {
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid rgba(16, 185, 129, 0.2);
            border-radius: 12px;
            padding: 1rem;
            margin-bottom: 2rem;
            color: var(--success);
            font-size: 0.875rem;
        }

        @@keyframes scaleIn {
            0% { transform: scale(0); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        .confetti-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            overflow: hidden;
            z-index: -1;
        }
    </style>
</head>
<body>
    <div class="glass-card animate-fade-in" style="text-align: center;">
        <div class="success-checkmark">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>

        <h1 class="text-gradient" style="font-size: 2rem; margin-bottom: 1rem;">Registration Complete!</h1>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        <p style="color: var(--text-secondary); line-height: 1.6; margin-bottom: 2.5rem;">
            We've sent a confirmation email to your inbox. Please follow the instructions in the email to activate your account and set up your permanent password.
        </p>

        <div style="border-top: 1px solid var(--glass-border); padding-top: 2rem;">
            <p style="font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 1.5rem;">
                Didn't receive the email? Check your spam folder or
            </p>
            <button onclick="window.location.href='@Url.Action("Index", "Registration")'" class="premium-button">
                <span>Start Over</span>
            </button>
        </div>
    </div>
</body>
</html>