@model EmailRegistrationApp.Models.RegistrationModel

@{
    ViewData["Title"] = "User Registration";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EmailRegistrationApp</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .form-label {
            display: block;
            margin-bottom: 8px;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-secondary);
            transition: color 0.3s ease;
        }

        .form-group:focus-within .form-label {
            color: #6366f1;
        }

        .validation-summary-errors {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-radius: 12px;
            padding: 1rem;
            margin-bottom: 2rem;
            color: var(--error);
            font-size: 0.875rem;
        }

        .validation-summary-errors ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .field-validation-error {
            color: var(--error);
            font-size: 0.75rem;
            margin-top: 4px;
            display: block;
        }

        .password-requirements {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 12px;
            padding: 1rem;
            margin-top: 0.75rem;
            font-size: 0.75rem;
            color: var(--text-secondary);
        }

        .password-requirements ul {
            margin: 0.5rem 0 0 1.25rem;
        }

        .button-stack {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-top: 2rem;
        }

        .secondary-btn {
            background: transparent;
            border: 1px solid var(--glass-border);
        }

        .secondary-btn:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(255, 255, 255, 0.3);
        }
    </style>
</head>
<body>
    <div class="glass-card animate-fade-in">
        <div style="text-align: center; margin-bottom: 2.5rem;">
            <h1 class="text-gradient" style="font-size: 2.5rem; margin-bottom: 0.5rem;">Create Account</h1>
            <p style="color: var(--text-secondary);">Join our platform today with a few clicks</p>
        </div>

        <form asp-action="RegisterUser" method="post" id="registrationForm">
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label asp-for="FirstName" class="form-label">First Name</label>
                    <input asp-for="FirstName" class="premium-input" placeholder="John" />
                    <span asp-validation-for="FirstName"></span>
                </div>

                <div class="form-group" style="margin-bottom: 1.5rem;">
                    <label asp-for="LastName" class="form-label">Last Name</label>
                    <input asp-for="LastName" class="premium-input" placeholder="Doe" />
                    <span asp-validation-for="LastName"></span>
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label asp-for="Email" class="form-label">Email Address</label>
                <input asp-for="Email" class="premium-input" type="email" placeholder="john@example.com" />
                <span asp-validation-for="Email"></span>
            </div>

            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label asp-for="TemporaryPassword" class="form-label">Temporary Password</label>
                <input asp-for="TemporaryPassword" type="password" class="premium-input" placeholder="••••••••••••" />
                <span asp-validation-for="TemporaryPassword"></span>
                <div class="password-requirements">
                    <strong>Password must contain:</strong>
                    <ul>
                        <li>At least 10 characters</li>
                        <li>Uppercase & Lowercase letters</li>
                        <li>Numeric digits & Special characters</li>
                    </ul>
                </div>
            </div>

            <div class="button-stack">
                <button type="submit" class="premium-button">
                    <span>Register User</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </button>
                <button type="submit" class="premium-button secondary-btn" formaction="@Url.Action("RegisterUserViaTemplate")">
                    <span>Register User via Template</span>
                </button>
            </div>
        </form>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>