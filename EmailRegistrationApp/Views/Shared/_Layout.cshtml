<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EmailRegistrationApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="container-fluid p-0 d-flex align-items-center justify-content-center" style="min-height: 100vh;">
        <main role="main" class="w-100 d-flex justify-content-center">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted" style="position: fixed; bottom: 20px; width: 100%; text-align: center; border: none;">
        <div class="container" style="color: var(--text-secondary); font-size: 0.875rem;">
            &copy; 2026 - EmailRegistrationApp - <a asp-area="" asp-controller="Home" asp-action="Privacy" style="color: var(--text-secondary); text-decoration: none;">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
